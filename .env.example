# Copy this to Netlify → Site Settings → Environment Variables
# Never commit real values to git

SHEET_ID=your_google_sheet_id_here
GOOGLE_API_KEY=your_api_key_here

# OAuth (for writes) — see README for how to get these
GOOGLE_CLIENT_ID=your_oauth_client_id
GOOGLE_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

# Login credentials for the app
AUTH_USER=your_username_here
AUTH_PASS=choose_a_strong_password_here
